PORT=4000

# Supabase — names must match exactly on Vercel (backend project, not the Next.js project unless same app).
# SUPABASE_URL = Project URL only: https://<project-ref>.supabase.co
#   NOT db.<ref>.supabase.co, NOT the pooler host, NOT .../rest/v1 (PostgREST error PGRST125 if wrong).
# SUPABASE_SERVICE_ROLE_KEY = service_role secret (Settings → API → service_role — long JWT). NOT the anon public key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
CORS_ORIGIN=http://localhost:3000

# PaddleOCR API (for bulk processing)
# Get token from https://aistudio.baidu.com/paddleocr/task
PADDLEOCR_API_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_TOKEN=your_paddleocr_token_here

# Bulk processing settings
BULK_BATCH_SIZE=20

# AWS S3 Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=btn-ai-documents-718383533470

# After changing env on Vercel: redeploy. Check GET /health → data.supabase (ready, keyDiagnosis).

PORT=4000

# Supabase — names must match exactly on Vercel (backend project, not the Next.js project unless same app).
# SUPABASE_URL = Project URL (Settings → API → Project URL)
# SUPABASE_SERVICE_ROLE_KEY = service_role secret (Settings → API → service_role — long JWT). NOT the anon public key.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
CORS_ORIGIN=http://localhost:3000

# After changing env on Vercel: redeploy. Check GET /health → data.supabase (ready, keyDiagnosis).
